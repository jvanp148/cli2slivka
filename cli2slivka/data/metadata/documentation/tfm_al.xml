<DsLSRAnalysis>
    <analysis
        name = "tfm"
        type = "Documentation"
        version = "6.6.0.0"
        supplier = "Confosoft Soaplab2 Emboss Docker container"
        installation = "Soaplab2 default installation"
        >
        <description>Display full documentation for an application</description>
        <input
            name = "program"
            type = "string"
            mandatory = "false"
            >
        </input>
        <input
            name = "html"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "more"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>

        <output
            name = "report"
            type = "string"
            >
        </output>
        <output
            name = "detailed_status"
            type = "long"
            >
        </output>
        <output
            name = "outfile"
            type = "string"
            >
        </output>
        <output
            name = "outfile_url"
            type = "string"
            >
        </output>

        <analysis_extension>
            <app_info
                category = "documentation"
                help_URL = "http://emboss.sourceforge.net/apps/release/6.3/emboss/apps/tfm.html"
                />
            <event
                id = "_E_1"
                >
                <action
                    type = "exe"
                    file = "tfm"
                    launcher = ""
                    >
                </action>

            </event>
            <parameter>
                <base
                    ordering = "2"
                    name = "program"
                    qualifier = "program"
                    mandatory = "false"
                    type = "string"
                    >
                    <prompt>Program to search for</prompt>
                    <help>Enter the name of an EMBOSS program</help>
                    <option
                        name = "EDAM_identifier:1194"
                        value = "Tool name (EMBOSS)"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "emboss program"
                        type = "normal"
                        />
                </base>

                <standard
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </standard>
            </parameter>
            <parameter>
                <base
                    ordering = "4"
                    name = "outfile"
                    qualifier = "outfile"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>stdout</default>
                    <prompt>Program documentation text output file</prompt>
                    <option
                        name = "EDAM_data:0958"
                        value = "Tool metadata"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "outfile"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "text documentation"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "stdout"
                    >
                    <result
                        name = "outfile"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "outfile_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "5"
                    name = "html"
                    qualifier = "html"
                    mandatory = "false"
                    type = "boolean"
                    >
                    <default>false</default>
                    <prompt>Format the output for HTML</prompt>
                    <help>This will format the output for displaying as a WWW
           document.</help>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                </base>

            </parameter>
            <parameter>
                <base
                    ordering = "6"
                    name = "more"
                    qualifier = "more"
                    mandatory = "false"
                    type = "boolean"
                    >
                    <default>false</default>
                    <prompt>Display a screenful at a time</prompt>
                    <help>This uses the standard UNIX utility 'more' to display the
           text page-by-page, waiting for you to read one screen-full before
           going on to the next page. When you have finished reading a page,
           press the SPACE bar to proceed to the next page.</help>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                    <option
                        name = "calculated_default"
                        value = "!${html}"
                        type = "normal"
                        />
                </base>

            </parameter>

            <option
                name = "EDAM_operation:0515"
                value = "Data retrieval (tool metadata)"
                type = "normal"
                />
            <option
                name = "EDAM_topic:0091"
                value = "Data handling"
                type = "normal"
                />
            <option
                name = "emboss"
                value = "true"
                type = "normal"
                />
            <option
                name = "installation"
                value = "Soaplab2 default installation"
                type = "normal"
                />
            <option
                name = "supplier"
                value = "Confosoft Soaplab2 Emboss Docker container"
                type = "normal"
                />
            <option
                name = "version"
                value = "6.6.0.0"
                type = "normal"
                />

        </analysis_extension>

    </analysis>

</DsLSRAnalysis>
