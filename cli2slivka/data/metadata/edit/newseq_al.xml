<DsLSRAnalysis>
    <analysis
        name = "newseq"
        type = "Edit"
        version = "6.6.0.0"
        supplier = "Confosoft Soaplab2 Emboss Docker container"
        installation = "Soaplab2 default installation"
        >
        <description>Create a sequence file from a typed-in sequence</description>
        <input
            name = "name"
            type = "string"
            mandatory = "true"
            >
        </input>
        <input
            name = "description"
            type = "string"
            mandatory = "true"
            >
        </input>
        <input
            name = "type"
            type = "string"
            mandatory = "false"
            >
            <default>N</default>
            <allowed>N</allowed>  <!-- Nucleic -->
            <allowed>P</allowed>  <!-- Protein -->
        </input>
        <input
            name = "sequence"
            type = "string"
            mandatory = "true"
            >
        </input>
        <input
            name = "osformat_outseq"
            type = "string"
            mandatory = "false"
            >
            <default>fasta</default>
            <allowed>acedb</allowed>
            <allowed>asn1</allowed>
            <allowed>bam</allowed>
            <allowed>clustal</allowed>
            <allowed>codata</allowed>
            <allowed>das</allowed>
            <allowed>dasdna</allowed>
            <allowed>embl</allowed>
            <allowed>experiment</allowed>
            <allowed>fasta</allowed>
            <allowed>fastq-illumina</allowed>
            <allowed>fastq-sanger</allowed>
            <allowed>fastq-solexa</allowed>
            <allowed>fitch</allowed>
            <allowed>gcg</allowed>
            <allowed>genbank</allowed>
            <allowed>genpept</allowed>
            <allowed>gff2</allowed>
            <allowed>gff3</allowed>
            <allowed>gifasta</allowed>
            <allowed>hennig86</allowed>
            <allowed>ig</allowed>
            <allowed>jackknifer</allowed>
            <allowed>jackknifernon</allowed>
            <allowed>mase</allowed>
            <allowed>mega</allowed>
            <allowed>meganon</allowed>
            <allowed>msf</allowed>
            <allowed>nbrf</allowed>
            <allowed>ncbi</allowed>
            <allowed>nexus</allowed>
            <allowed>nexusnon</allowed>
            <allowed>phylip</allowed>
            <allowed>phylipnon</allowed>
            <allowed>pir</allowed>
            <allowed>raw</allowed>
            <allowed>refseq</allowed>
            <allowed>refseqp</allowed>
            <allowed>sam</allowed>
            <allowed>selex</allowed>
            <allowed>staden</allowed>
            <allowed>strider</allowed>
            <allowed>swiss</allowed>
            <allowed>text</allowed>
            <allowed>treecon</allowed>
        </input>

        <output
            name = "report"
            type = "string"
            >
        </output>
        <output
            name = "detailed_status"
            type = "long"
            >
        </output>
        <output
            name = "outseq"
            type = "string"
            >
        </output>
        <output
            name = "outseq_url"
            type = "string"
            >
        </output>

        <analysis_extension>
            <app_info
                category = "edit"
                help_URL = "http://emboss.sourceforge.net/apps/release/6.3/emboss/apps/newseq.html"
                />
            <event
                id = "_E_1"
                >
                <action
                    type = "exe"
                    file = "newseq"
                    launcher = ""
                    >
                </action>

            </event>
            <parameter>
                <base
                    ordering = "2"
                    name = "name"
                    qualifier = "name"
                    mandatory = "true"
                    type = "string"
                    >
                    <prompt>Name of the sequence</prompt>
                    <help>The name of of the sequence should be a single word that
           you will use to identify the sequence. It should have no (or few)
           punctuation characters in it.</help>
                    <option
                        name = "EDAM_identifier:2154"
                        value = "Sequence name"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "name"
                        type = "normal"
                        />
                </base>

                <standard
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </standard>
            </parameter>
            <parameter>
                <base
                    ordering = "3"
                    name = "description"
                    qualifier = "description"
                    mandatory = "true"
                    type = "string"
                    >
                    <prompt>Description of the sequence</prompt>
                    <help>Enter any description of the sequence that you require.</help>
                    <option
                        name = "EDAM_data:2048"
                        value = "Report"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "string"
                        type = "normal"
                        />
                </base>

                <standard
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </standard>
            </parameter>
            <parameter>
                <base
                    ordering = "4"
                    name = "type"
                    qualifier = "type"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>N</default>
                    <prompt>Type of sequence</prompt>
                    <option
                        name = "EDAM_data:1094"
                        value = "Sequence type"
                        type = "normal"
                        />
                    <option
                        name = "readonly"
                        value = "true"
                        type = "style"
                        />
                </base>

                <standard
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                    <list
                        name = "Type of sequence"
                        type = "full"
                        >
                        <list_item
                            value = "N"
                            shown_as = "Nucleic"
                            level = "0"
                            />
                        <list_item
                            value = "P"
                            shown_as = "Protein"
                            level = "0"
                            />
                    </list>
                </standard>
            </parameter>
            <parameter>
                <base
                    ordering = "5"
                    name = "sequence"
                    qualifier = "sequence"
                    mandatory = "true"
                    type = "string"
                    >
                    <prompt>Enter the sequence</prompt>
                    <help>The sequence itself. 
           Because of the limitation of the operating system, you will only
           be able to type in a short sequence of (typically) 250 characters,
           or so. 
           The keyboard will beep at you when you have reached this limit and
           you will not be able to press the RETURN/ENTER key until you have
           deleted a few characters.</help>
                    <option
                        name = "EDAM_data:0848"
                        value = "Raw sequence"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "sequence"
                        type = "normal"
                        />
                </base>

                <standard
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </standard>
            </parameter>
            <parameter>
                <base
                    ordering = "7"
                    name = "outseq"
                    qualifier = "outseq"
                    mandatory = "false"
                    type = "string"
                    >
                    <help>Returns sequence.</help>
                    <option
                        name = "EDAM_data:0849"
                        value = "Sequence record"
                        type = "normal"
                        />
                    <option
                        name = "calculated_type"
                        value = "@(${type} == P) ? gapprotein : gapnucleotide"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "gendata"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "output"
                    >
                    <result
                        name = "outseq"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "outseq_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    name = "osformat_outseq"
                    qualifier = "osformat_outseq"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>fasta</default>
                    <prompt>Format of the output sequence (outseq)</prompt>
                    <option
                        name = "readonly"
                        value = "true"
                        type = "style"
                        />
                </base>

