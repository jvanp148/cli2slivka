                    name = "infile"
                    qualifier = "infile"
                    mandatory = "false"
                    type = "string"
                    >
                    <prompt>Program compseq output file (optional)</prompt>
                    <help>This is a file previously produced by 'compseq' that can be
           used to set the expected frequencies of words in this analysis. 
           The word size in the current run must be the same as the one in
           this results file. Obviously, you should use a file produced from
           protein sequences if you are counting protein sequence word
           frequencies, and you must use one made from nucleotide frequencies
           if you are analysing a nucleotide sequence.</help>
                    <option
                        name = "EDAM_data:1261"
                        value = "Sequence composition"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "input"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "compseq output"
                        type = "normal"
                        />
                </base>

                <data
                    iotype = "input"
                    ioformat = "unspecified"
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "6"
                    name = "word"
                    qualifier = "word"
                    mandatory = "false"
                    type = "long"
                    >
                    <default>2</default>
                    <prompt>Word size to consider (e.g. 2=dimer)</prompt>
                    <help>This is the size of word (n-mer) to count. 
           Thus if you want to count codon frequencies for a nucleotide
           sequence, you should enter 3 here.</help>
                    <option
                        name = "EDAM_data:1250"
                        value = "Word size"
                        type = "normal"
                        />
                    <option
                        name = "calculated_hardmax"
                        value = "${acdprotein}? 4 : 6"
                        type = "normal"
                        />
                    <option
                        name = "scalemin"
                        value = "1"
                        type = "style"
                        />
                </base>

                <range
                    min = "1"
                    max = ""
                    format = "%d"
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </range>
            </parameter>
            <parameter>
                <base
                    ordering = "10"
                    name = "ignorebz"
                    qualifier = "ignorebz"
                    mandatory = "false"
                    type = "boolean"
                    >
                    <default>false</default>
                    <prompt>Ignore the amino acids B and Z and just count
                  them as 'Other'</prompt>
                    <help>The amino acid code B represents Asparagine or Aspartic
           acid and the code Z represents Glutamine or Glutamic acid. 
           These are not commonly used codes and you may wish not to count
           words containing them, just noting them in the count of 'Other'
           words.</help>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                </base>

            </parameter>
            <parameter>
                <base
                    ordering = "11"
                    name = "reverse"
                    qualifier = "reverse"
                    mandatory = "false"
                    type = "boolean"
                    >
                    <default>false</default>
                    <prompt>Count words in the forward and reverse sense</prompt>
                    <help>Set this to be true if you also wish to also count words in
           the reverse complement of a nucleic sequence.</help>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                </base>

            </parameter>
            <parameter>
                <base
                    ordering = "12"
                    name = "calcfreq"
                    qualifier = "calcfreq"
                    mandatory = "false"
                    type = "boolean"
                    >
                    <default>false</default>
                    <prompt>Calculate expected frequency from sequence</prompt>
                    <help>If this is set true then the expected frequencies of words
           are calculated from the observed frequency of single bases or
           residues in the sequences. 
           If you are reporting a word size of 1 (single bases or residues)
           then there is no point in using this option because the calculated
           expected frequency will be equal to the observed frequency. 
           Calculating the expected frequencies like this will give an
           approximation of the expected frequencies that you might get by
           using an input file of frequencies produced by a previous run of
           this program. If an input file of expected word frequencies has
           been specified then the values from that file will be used instead
           of this calculation of expected frequency from the sequence, even
           if 'calcfreq' is set to be true.</help>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                </base>

            </parameter>
            <parameter>
                <base
                    ordering = "16"
                    name = "zerocount"
                    qualifier = "zerocount"
                    mandatory = "false"
                    type = "boolean"
                    >
                    <default>false</default>
                    <prompt>Display the words that have a frequency of
                  zero</prompt>
                    <help>You can make the output results file much smaller if you do
           not display the words with a zero count.</help>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                </base>

            </parameter>

