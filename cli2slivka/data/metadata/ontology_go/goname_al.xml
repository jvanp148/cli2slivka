<DsLSRAnalysis>
    <analysis
        name = "goname"
        type = "Ontology GO, Data retrieval Ontology data"
        version = "6.6.0.0"
        supplier = "Confosoft Soaplab2 Emboss Docker container"
        installation = "Soaplab2 default installation"
        >
        <description>Find GO ontology terms by name</description>
        <input
            name = "query"
            type = "string"
            mandatory = "false"
            >
        </input>
        <input
            name = "namespace_biological_process"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "namespace_cellular_component"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "namespace_molecular_function"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "subclasses"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "obsolete"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>

        <output
            name = "report"
            type = "string"
            >
        </output>
        <output
            name = "detailed_status"
            type = "long"
            >
        </output>
        <output
            name = "outfile"
            type = "string"
            >
        </output>
        <output
            name = "outfile_url"
            type = "string"
            >
        </output>

        <analysis_extension>
            <app_info
                category = "ontology_go"
                help_URL = "http://emboss.sourceforge.net/apps/release/6.3/emboss/apps/goname.html"
                />
            <event
                id = "_E_1"
                >
                <action
                    type = "exe"
                    file = "goname"
                    launcher = ""
                    >
                </action>

            </event>
            <parameter>
                <base
                    ordering = "2"
                    name = "query"
                    qualifier = "query"
                    mandatory = "false"
                    type = "string"
                    >
                    <prompt>Name(s) to search for in ontology</prompt>
                    <option
                        name = "EDAM_data:0968"
                        value = "Keyword"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "keyword"
                        type = "normal"
                        />
                </base>

                <standard
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </standard>
            </parameter>
            <parameter>
                <base
                    ordering = "14"
                    name = "outfile"
                    qualifier = "outfile"
                    mandatory = "false"
                    type = "string"
                    >
                    <option
                        name = "EDAM_data:2223"
                        value = "Ontology metadata"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "outfile"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "output"
                    >
                    <result
                        name = "outfile"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "outfile_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "4"
                    name = "namespace"
                    qualifier = "namespace"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>*</default>
                    <prompt>GO namespace(s)</prompt>
                    <help>By default all terms are returned. Searches can be limited
      	    to one or a few namespaces.</help>
                    <option
                        name = "EDAM_data:0967"
                        value = "Ontology concept metadata"
                        type = "normal"
                        />
                    <option
                        name = "columns"
                        value = "4"
                        type = "style"
                        />
                </base>

                <choice_list
                    grouptype = "zero_or_more"
                    separator = ","
                    >
                    <base
                        ordering = "5"
                        name = "namespace_biological_process"
                        qualifier = "biological_process"
                        mandatory = "false"
                        type = "boolean"
                        >
                        <default>false</default>
                        <prompt>Biological process</prompt>
                    </base>
                    <base
                        ordering = "6"
                        name = "namespace_cellular_component"
                        qualifier = "cellular_component"
                        mandatory = "false"
                        type = "boolean"
                        >
                        <default>false</default>
                        <prompt>Cellular component</prompt>
                    </base>
                    <base
                        ordering = "7"
                        name = "namespace_molecular_function"
                        qualifier = "molecular_function"
                        mandatory = "false"
                        type = "boolean"
                        >
                        <default>false</default>
                        <prompt>Molecular function</prompt>
                    </base>
                </choice_list>
            </parameter>
            <parameter>
                <base
                    ordering = "10"
                    name = "subclasses"
                    qualifier = "subclasses"
                    mandatory = "false"
                    type = "boolean"
                    >
                    <default>false</default>
                    <prompt>Include subclasses of hits</prompt>
                    <help>Extend the query matches to include all terms which are
           specialisations (GO sub-classes) of the matched type.</help>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                </base>

            </parameter>
            <parameter>
                <base
                    ordering = "11"
                    name = "obsolete"
                    qualifier = "obsolete"
                    mandatory = "false"
                    type = "boolean"
                    >
                    <default>false</default>
                    <prompt>Include obsolete terms</prompt>
                    <help>The default behaviour is to not use or return obsolete terms.
           This option if set will include all terms.</help>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                </base>

            </parameter>

            <option
                name = "EDAM_operation:2422"
                value = "Data retrieval"
                type = "normal"
                />
            <option
                name = "EDAM_topic:0089"
                value = "Ontology"
                type = "normal"
                />
            <option
                name = "EDAM_topic:0090"
                value = "Data search and retrieval"
                type = "normal"
                />
            <option
                name = "emboss"
                value = "true"
                type = "normal"
                />
            <option
                name = "installation"
                value = "Soaplab2 default installation"
                type = "normal"
                />
            <option
                name = "supplier"
                value = "Confosoft Soaplab2 Emboss Docker container"
                type = "normal"
                />
            <option
                name = "version"
                value = "6.6.0.0"
                type = "normal"
                />

        </analysis_extension>

    </analysis>

</DsLSRAnalysis>
