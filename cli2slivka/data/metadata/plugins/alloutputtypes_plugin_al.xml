<DsLSRAnalysis>
    <analysis
        name = "alloutputtypes_plugin"
        type = "Plugins,Testing"
        installation = "Soaplab2 default installation"
        >
        <description>Showing how a plugin can create all kinds of outputs</description>
        <input
            name = "input_direct_data"
            type = "string"
            mandatory = "false"
            >
        </input>
        <input
            name = "input_url"
            type = "string"
            mandatory = "false"
            >
        </input>
        <input
            name = "count"
            type = "long"
            mandatory = "false"
            >
            <default>3</default>
        </input>

        <output
            name = "report"
            type = "string"
            >
        </output>
        <output
            name = "detailed_status"
            type = "long"
            >
        </output>
        <output
            name = "simple_text_output"
            type = "string"
            >
        </output>
        <output
            name = "simple_text_output_url"
            type = "string"
            >
        </output>
        <output
            name = "simple_binary_output"
            type = "byte[]"
            >
        </output>
        <output
            name = "simple_binary_output_url"
            type = "string"
            >
        </output>
        <output
            name = "array_text_output"
            type = "String[]"
            >
        </output>
        <output
            name = "array_text_output_url"
            type = "string"
            >
        </output>
        <output
            name = "array_binary_output"
            type = "byte[][]"
            >
        </output>
        <output
            name = "array_binary_output_url"
            type = "String[]"
            >
        </output>

        <analysis_extension>
            <app_info
                category = "plugins"
                />
            <event
                id = "_E_1"
                >
                <action
                    type = "exe"
                    file = "alloutputtypes_plugin"
                    launcher = ""
                    >
                </action>

            </event>
            <parameter>
                <base
                    ordering = "1"
                    name = "input"
                    qualifier = "input"
                    mandatory = "true"
                    type = "string"
                    >
                    <help>This input will be copied to several outputs. &lt;p&gt;
         For some of outputs, it will be even replicated
         (how many times, it depends on the parameter &lt;em&gt;count&lt;/em&gt;).</help>
                    <option
                        name = "datatype"
                        value = "input"
                        type = "normal"
                        />
                </base>

                <data
                    iotype = "input"
                    ioformat = "unspecified"
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "2"
                    name = "count"
                    qualifier = "count"
                    mandatory = "false"
                    type = "long"
                    use_defaults = "true"
                    >
                    <default>3</default>
                    <prompt>How many times to replicate input in the array outputs</prompt>
                </base>

                <range
                    format = "%d"
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </range>
            </parameter>
            <parameter>
                <base
                    ordering = "3"
                    name = "simple_text_output"
                    qualifier = "simple_text_output"
                    mandatory = "false"
                    type = "string"
                    >
                    <option
                        name = "datatype"
                        value = "outfile"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "output"
                    >
                    <result
                        name = "simple_text_output"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "simple_text_output_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "4"
                    name = "simple_binary_output"
                    qualifier = "simple_binary_output"
                    mandatory = "false"
                    type = "string"
                    >
                    <option
                        name = "datatype"
                        value = "bindata"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "output"
                    >
                    <result
                        name = "simple_binary_output"
                        type = "byte[]"
                        >
                    </result>
                    <result
                        name = "simple_binary_output_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "5"
                    name = "array_text_output"
                    qualifier = "array_text_output"
                    mandatory = "false"
                    type = "String[]"
                    >
                    <option
                        name = "datatype"
                        value = "outfile"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "output"
                    >
                    <result
                        name = "array_text_output"
                        type = "String[]"
                        >
                    </result>
                    <result
                        name = "array_text_output_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "6"
                    name = "array_binary_output"
                    qualifier = "array_binary_output"
                    mandatory = "false"
                    type = "byte[][]"
                    >
                    <option
                        name = "datatype"
                        value = "bindata"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "output"
                    >
                    <result
                        name = "array_binary_output"
                        type = "byte[][]"
                        >
                    </result>
                    <result
                        name = "array_binary_output_url"
                        type = "String[]"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>

            <option
                name = "class"
                value = "org.soaplab.samples.OutputTypesJobFactory"
                type = "normal"
                />
            <option
                name = "emboss"
                value = "false"
                type = "normal"
                />
            <option
                name = "installation"
                value = "Soaplab2 default installation"
                type = "normal"
                />

        </analysis_extension>

    </analysis>

</DsLSRAnalysis>
