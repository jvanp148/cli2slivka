<DsLSRAnalysis>
    <analysis
        name = "embossdata"
        type = "Utils"
        version = "6.6.0.0"
        supplier = "Confosoft Soaplab2 Emboss Docker container"
        installation = "Soaplab2 default installation"
        >
        <description>Find and retrieve EMBOSS data files</description>
        <input
            name = "filename"
            type = "string"
            mandatory = "false"
            >
        </input>
        <input
            name = "showall"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "fetch"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "reject_None"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "reject_AAINDEX"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "reject_CVS"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "reject_CODONS"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "reject_PRINTS"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "reject_PROSITE"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "reject_REBASE"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>

        <output
            name = "report"
            type = "string"
            >
        </output>
        <output
            name = "detailed_status"
            type = "long"
            >
        </output>
        <output
            name = "outfile"
            type = "string"
            >
        </output>
        <output
            name = "outfile_url"
            type = "string"
            >
        </output>

        <analysis_extension>
            <app_info
                category = "utils"
                help_URL = "http://emboss.sourceforge.net/apps/release/6.3/emboss/apps/embossdata.html"
                />
            <event
                id = "_E_1"
                >
                <action
                    type = "exe"
                    file = "embossdata"
                    launcher = ""
                    >
                </action>

            </event>
            <parameter>
                <base
                    ordering = "4"
                    name = "filename"
                    qualifier = "filename"
                    mandatory = "false"
                    type = "string"
                    >
                    <prompt>Data file name</prompt>
                    <help>This specifies the name of the file that should be fetched
           into the current directory or searched for in all of the
           directories that EMBOSS programs search when looking for a data
           file. The name of the file is not altered when it is fetched.</help>
                    <option
                        name = "EDAM_identifier:1050"
                        value = "File name"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "filename"
                        type = "normal"
                        />
                </base>

                <standard
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </standard>
            </parameter>
            <parameter>
                <base
                    ordering = "2"
                    name = "showall"
                    qualifier = "showall"
                    mandatory = "false"
                    type = "boolean"
                    >
                    <default>false</default>
                    <prompt>Show all potential EMBOSS data files</prompt>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                </base>

            </parameter>
            <parameter>
                <base
                    ordering = "3"
                    name = "fetch"
                    qualifier = "fetch"
                    mandatory = "false"
                    type = "boolean"
                    >
                    <default>false</default>
                    <prompt>Fetch a data file</prompt>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                </base>

            </parameter>
            <parameter>
                <base
                    ordering = "7"
                    name = "reject"
                    qualifier = "reject"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>3, 5, 6</default>
                    <prompt>Directories to ignore</prompt>
                    <help>This specifies the names of the sub-directories of the
           EMBOSS data directory that should be ignored when displaying data
           directories.</help>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                    <option
                        name = "columns"
                        value = "4"
                        type = "style"
                        />
                </base>

                <choice_list
                    grouptype = "zero_or_more"
                    separator = ","
                    >
                    <base
                        ordering = "8"
                        name = "reject_None"
                        qualifier = "None"
                        mandatory = "false"
                        type = "boolean"
                        >
                        <default>false</default>
                    </base>
                    <base
                        ordering = "9"
                        name = "reject_AAINDEX"
                        qualifier = "AAINDEX"
                        mandatory = "false"
                        type = "boolean"
                        >
                        <default>false</default>
                    </base>
                    <base
                        ordering = "10"
                        name = "reject_CVS"
                        qualifier = "CVS"
                        mandatory = "false"
                        type = "boolean"
                        >
                        <default>false</default>
                    </base>
                    <base
                        ordering = "11"
                        name = "reject_CODONS"
                        qualifier = "CODONS"
                        mandatory = "false"
                        type = "boolean"
                        >
                        <default>false</default>
                    </base>
                    <base
                        ordering = "12"
                        name = "reject_PRINTS"
                        qualifier = "PRINTS"
                        mandatory = "false"
                        type = "boolean"
                        >
                        <default>false</default>
                    </base>
                    <base
                        ordering = "13"
                        name = "reject_PROSITE"
                        qualifier = "PROSITE"
                        mandatory = "false"
                        type = "boolean"
                        >
                        <default>false</default>
                    </base>
                    <base
                        ordering = "14"
                        name = "reject_REBASE"
                        qualifier = "REBASE"
                        mandatory = "false"
                        type = "boolean"
                        >
                        <default>false</default>
                    </base>
                </choice_list>
            </parameter>
            <parameter>
                <base
                    ordering = "17"
                    name = "outfile"
                    qualifier = "outfile"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>stdout</default>
                    <prompt>EMBOSS datafile output file</prompt>
                    <help>This specifies the name of the file that the results of a
           search for a file in the various data directories is written to.
           By default these results are written to the screen (stdout).</help>
                    <option
                        name = "EDAM_data:0957"
                        value = "Database metadata"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "outfile"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "emboss datafile"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "stdout"
                    >
                    <result
                        name = "outfile"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "outfile_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>

            <option
                name = "EDAM_operation:1812"
                value = "Data loading"
                type = "normal"
                />
            <option
                name = "EDAM_operation:2422"
                value = "Data retrieval"
                type = "normal"
                />
            <option
                name = "EDAM_topic:0091"
                value = "Data handling"
                type = "normal"
                />
            <option
                name = "emboss"
                value = "true"
                type = "normal"
                />
            <option
                name = "installation"
                value = "Soaplab2 default installation"
                type = "normal"
                />
            <option
                name = "supplier"
                value = "Confosoft Soaplab2 Emboss Docker container"
                type = "normal"
                />
            <option
                name = "version"
                value = "6.6.0.0"
                type = "normal"
                />

        </analysis_extension>

    </analysis>

</DsLSRAnalysis>
