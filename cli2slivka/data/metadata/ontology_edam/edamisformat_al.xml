<DsLSRAnalysis>
    <analysis
        name = "edamisformat"
        type = "Ontology EDAM, Data retrieval Ontology data"
        version = "6.6.0.0"
        supplier = "Confosoft Soaplab2 Emboss Docker container"
        installation = "Soaplab2 default installation"
        >
        <description>Find EDAM ontology terms by is_format_of relation</description>
        <input
            name = "identifier"
            type = "string"
            mandatory = "false"
            >
        </input>
        <input
            name = "namespace_data"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "namespace_entity"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "namespace_format"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "namespace_identifier"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "namespace_operation"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "namespace_resource"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "namespace_topic"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "sensitive"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "subclasses"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "obsolete"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>

        <output
            name = "report"
            type = "string"
            >
        </output>
        <output
            name = "detailed_status"
            type = "long"
            >
        </output>
        <output
            name = "outfile"
            type = "string"
            >
        </output>
        <output
            name = "outfile_url"
            type = "string"
            >
        </output>

        <analysis_extension>
            <app_info
                category = "ontology_edam"
                help_URL = "http://emboss.sourceforge.net/apps/release/6.3/emboss/apps/edamisformat.html"
                />
            <event
                id = "_E_1"
                >
                <action
                    type = "exe"
                    file = "edamisformat"
                    launcher = ""
                    >
                </action>

            </event>
            <parameter>
                <base
                    ordering = "2"
                    name = "identifier"
                    qualifier = "identifier"
                    mandatory = "false"
                    type = "string"
                    >
                    <prompt>Identifier(s) to search for in ontology</prompt>
                    <option
                        name = "EDAM_data:0968"
                        value = "Keyword"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "keyword"
                        type = "normal"
                        />
                </base>

                <standard
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </standard>
            </parameter>
            <parameter>
                <base
                    ordering = "19"
                    name = "outfile"
                    qualifier = "outfile"
                    mandatory = "false"
                    type = "string"
                    >
                    <option
                        name = "EDAM_data:2223"
                        value = "Ontology metadata"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "outfile"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "output"
                    >
                    <result
                        name = "outfile"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "outfile_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "4"
                    name = "namespace"
                    qualifier = "namespace"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>*</default>
                    <prompt>EDAM namespace(s)</prompt>
                    <help>By default all terms are returned. Searches can be limited
      	    to one or a few namespaces.</help>
                    <option
                        name = "EDAM_data:0967"
                        value = "Ontology concept metadata"
                        type = "normal"
                        />
                    <option
                        name = "columns"
                        value = "2"
                        type = "style"
                        />
                </base>

                <choice_list
                    grouptype = "zero_or_more"
                    separator = ","
                    >
                    <base
                        ordering = "5"
                        name = "namespace_data"
                        qualifier = "data"
                        mandatory = "false"
                        type = "boolean"
                        >
                        <default>false</default>
                        <prompt>Data entity</prompt>
                    </base>
                    <base
                        ordering = "6"
                        name = "namespace_entity"
                        qualifier = "entity"
                        mandatory = "false"
                        type = "boolean"
                        >
                        <default>false</default>
                        <prompt>Biological entity</prompt>
                    </base>
                    <base
                        ordering = "7"
                        name = "namespace_format"
                        qualifier = "format"
                        mandatory = "false"
                        type = "boolean"
                        >
                        <default>false</default>
                        <prompt>Data format</prompt>
                    </base>
                    <base
                        ordering = "8"
                        name = "namespace_identifier"
                        qualifier = "identifier"
                        mandatory = "false"
                        type = "boolean"
                        >
                        <default>false</default>
                        <prompt>Identifier</prompt>
                    </base>
                    <base
                        ordering = "9"
                        name = "namespace_operation"
                        qualifier = "operation"
                        mandatory = "false"
                        type = "boolean"
                        >
                        <default>false</default>
                        <prompt>Bioinformatics operation</prompt>
                    </base>
                    <base
                        ordering = "10"
                        name = "namespace_resource"
                        qualifier = "resource"
                        mandatory = "false"
                        type = "boolean"
                        >
                        <default>false</default>
                        <prompt>Data resource</prompt>
                    </base>
                    <base
                        ordering = "11"
                        name = "namespace_topic"
                        qualifier = "topic"
                        mandatory = "false"
                        type = "boolean"
                        >
                        <default>false</default>
                        <prompt>Field of bioinformatics study</prompt>
                    </base>
                </choice_list>
            </parameter>
            <parameter>
                <base
                    ordering = "14"
                    name = "sensitive"
                    qualifier = "sensitive"
                    mandatory = "false"
                    type = "boolean"
                    >
                    <default>false</default>
                    <prompt>Increase sensitivity of search</prompt>
                    <help>By default, the query keywords are matched against the EDAM
          term names (and synonyms) only. This option also matches the
	  keywords against the EDAM term definitions and will therefore
	  (typically) report more matches.</help>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                </base>

            </parameter>
            <parameter>
                <base
                    ordering = "15"
                    name = "subclasses"
                    qualifier = "subclasses"
                    mandatory = "false"
                    type = "boolean"
                    >
                    <default>false</default>
                    <prompt>Include subclasses of hits</prompt>
                    <help>Extend the query matches to include all terms which are
           specialisations (EDAM sub-classes) of the matched type.</help>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                </base>

            </parameter>
            <parameter>
                <base
                    ordering = "16"
                    name = "obsolete"
                    qualifier = "obsolete"
                    mandatory = "false"
                    type = "boolean"
                    >
                    <default>false</default>
                    <prompt>Include obsolete terms</prompt>
                    <help>The default behaviour is to not use or return obsolete terms.
           This option if set will include all terms.</help>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                </base>

            </parameter>

            <option
                name = "EDAM_operation:2422"
                value = "Data retrieval"
                type = "normal"
                />
            <option
                name = "EDAM_topic:0089"
                value = "Ontology"
                type = "normal"
                />
            <option
                name = "EDAM_topic:0090"
                value = "Data search and retrieval"
                type = "normal"
                />
            <option
                name = "emboss"
                value = "true"
                type = "normal"
                />
            <option
                name = "installation"
                value = "Soaplab2 default installation"
                type = "normal"
                />
            <option
                name = "supplier"
                value = "Confosoft Soaplab2 Emboss Docker container"
                type = "normal"
                />
            <option
                name = "version"
                value = "6.6.0.0"
                type = "normal"
                />

        </analysis_extension>

    </analysis>

</DsLSRAnalysis>
