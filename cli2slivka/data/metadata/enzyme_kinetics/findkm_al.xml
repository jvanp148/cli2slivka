        <input
            name = "infile_direct_data"
            type = "string"
            mandatory = "false"
            >
        </input>
        <input
            name = "infile_url"
            type = "string"
            mandatory = "false"
            >
        </input>
        <input
            name = "graph_format"
            type = "string"
            mandatory = "false"
            >
            <default>png</default>
            <allowed>png</allowed>  <!-- Portable Network Graphics (png) -->
            <allowed>colourps</allowed>  <!-- Postscript -->
        </input>
        <input
            name = "plot"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>

        <output
            name = "report"
            type = "string"
            >
        </output>
        <output
            name = "detailed_status"
            type = "long"
            >
        </output>
        <output
            name = "outfile"
            type = "string"
            >
        </output>
        <output
            name = "outfile_url"
            type = "string"
            >
        </output>
        <output
            name = "Graphics_in_Postscript"
            type = "string"
            >
        </output>
        <output
            name = "Graphics_in_Postscript_url"
            type = "string"
            >
        </output>
        <output
            name = "Graphics_in_PNG"
            type = "byte[][]"
            >
        </output>
        <output
            name = "Graphics_in_PNG_url"
            type = "String[]"
            >
        </output>

        <analysis_extension>
            <app_info
