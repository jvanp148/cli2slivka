                help_URL = "http://emboss.sourceforge.net/apps/release/6.3/emboss/apps/findkm.html"
                />
            <event
                id = "_E_1"
                >
                <action
                    type = "exe"
                    file = "findkm"
                    launcher = ""
                    >
                </action>

            </event>
            <parameter>
                <base
                    ordering = "2"
                    name = "infile"
                    qualifier = "infile"
                    mandatory = "true"
                    type = "string"
                    >
                    <prompt>Enzyme kinetics data (application-specific)
                  file</prompt>
                    <option
                        name = "EDAM_data:2024"
                        value = "Enzyme kinetics data"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "input"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "enzyme data"
                        type = "normal"
                        />
                </base>

                <data
                    iotype = "input"
                    ioformat = "unspecified"
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "7"
                    name = "outfile"
                    qualifier = "outfile"
                    mandatory = "false"
                    type = "string"
                    >
                    <option
                        name = "EDAM_data:2978"
                        value = "Reaction data"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "outfile"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "findkm output"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "output"
                    >
                    <result
                        name = "outfile"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "outfile_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "8"
                    name = "graph_format"
                    qualifier = "graph_format"
                    mandatory = "false"
                    type = "string"
                    use_defaults = "true"
                    envar = "true"
                    >
                    <default>png</default>
                    <prompt>Format of the graphical output</prompt>
                    <option
                        name = "EDAM_data:2025"
                        value = "Michaelis Menten plot"
                        type = "normal"
                        />
                    <option
                        name = "EDAM_data:2026"
                        value = "Hanes Woolf plot"
                        type = "normal"
                        />
                    <option
                        name = "readonly"
                        value = "true"
                        type = "style"
                        />
                </base>

                <standard
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                    <list
                        type = "full"
                        >
                        <list_item
                            value = "png"
                            shown_as = "Portable Network Graphics (png)"
                            level = "0"
                            />
                        <list_item
                            value = "colourps"
                            shown_as = "Postscript"
                            level = "0"
                            />
                    </list>
                </standard>
            </parameter>
            <parameter>
                <base
                    ordering = "4"
                    name = "plot"
                    qualifier = "plot"
                    mandatory = "false"
                    type = "boolean"
                    >
                    <default>false</default>
                    <prompt>S/V vs S</prompt>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                </base>

            </parameter>
            <parameter>
                <base
                    ordering = "8"
                    name = "Graphics_in_Postscript"
                    qualifier = "Graphics_in_Postscript"
                    method = "%%%Graphics_in_Postscript%%% ${Graphics_in_Postscript}"
                    mandatory = "false"
                    type = "string"
                    >
                    <option
                        name = "EDAM_data:2025"
                        value = "Michaelis Menten plot"
                        type = "normal"
                        />
                    <option
                        name = "EDAM_data:2026"
                        value = "Hanes Woolf plot"
                        type = "normal"
                        />
                    <option
                        name = "allow_non_existent"
                        value = "true"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "graph"
                        type = "normal"
                        />
                    <option
                        name = "mimetype"
                        value = "application/postscript"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "output"
                    >
                    <result
                        name = "Graphics_in_Postscript"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "Graphics_in_Postscript_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "8"
                    name = "Graphics_in_PNG"
                    qualifier = "Graphics_in_PNG"
                    method = "%%%Graphics_in_PNG%%% ${Graphics_in_PNG}"
                    mandatory = "false"
                    type = "byte[][]"
                    >
                    <option
                        name = "EDAM_data:2025"
                        value = "Michaelis Menten plot"
                        type = "normal"
                        />
                    <option
                        name = "EDAM_data:2026"
                        value = "Hanes Woolf plot"
                        type = "normal"
                        />
                    <option
                        name = "allow_non_existent"
                        value = "true"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "bindata"
                        type = "normal"
                        />
                    <option
                        name = "mimetype"
                        value = "image/png"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "output"
                    >
                    <result
                        name = "Graphics_in_PNG"
                        type = "byte[][]"
                        >
                    </result>
                    <result
                        name = "Graphics_in_PNG_url"
                        type = "String[]"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>

            <option
                name = "EDAM_operation:0334"
                value = "Enzyme kinetics calculation"
                type = "normal"
                />
            <option
                name = "EDAM_topic:0821"
                value = "Enzymes and reactions"
                type = "normal"
                />
            <option
                name = "emboss"
                value = "true"
                type = "normal"
                />
            <option
                name = "installation"
                value = "Soaplab2 default installation"
                type = "normal"
                />
            <option
                name = "supplier"
                value = "Confosoft Soaplab2 Emboss Docker container"
                type = "normal"
                />
            <option
                name = "version"
                value = "6.6.0.0"
                type = "normal"
                />

        </analysis_extension>

    </analysis>

</DsLSRAnalysis>
