<DsLSRAnalysis>
    <analysis
        name = "streams"
        type = "Testing"
        installation = "Soaplab2 default installation"
        >
        <description>Filtering stdin into stdout and stderr streams</description>
        <input
            name = "exitcode"
            type = "long"
            mandatory = "false"
            >
            <default>0</default>
        </input>
        <input
            name = "input"
            type = "string"
            mandatory = "false"
            >
        </input>

        <output
            name = "report"
            type = "string"
            >
        </output>
        <output
            name = "detailed_status"
            type = "long"
            >
        </output>
        <output
            name = "std_output"
            type = "string"
            >
        </output>
        <output
            name = "std_output_url"
            type = "string"
            >
        </output>
        <output
            name = "std_errors"
            type = "string"
            >
        </output>
        <output
            name = "std_errors_url"
            type = "string"
            >
        </output>

        <analysis_extension>
            <app_info
                category = "testing"
                />
            <event
                id = "_E_1"
                >
                <action
                    type = "exe"
                    file = "all-streams.pl"
                    launcher = ""
                    >
                </action>

            </event>
            <parameter>
                <base
                    ordering = "1"
                    name = "exitcode"
                    qualifier = "exitcode"
                    mandatory = "false"
                    type = "long"
                    >
                    <default>0</default>
                    <option
                        name = "qualifier"
                        value = "e"
                        type = "normal"
                        />
                </base>

                <range
                    format = "%d"
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </range>
            </parameter>
            <parameter>
                <base
                    ordering = "2"
                    name = "input"
                    qualifier = "input"
                    mandatory = "false"
                    type = "string"
                    >
                    <option
                        name = "datatype"
                        value = "input"
                        type = "normal"
                        />
                </base>

                <data
                    iotype = "stdin"
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "3"
                    name = "std_output"
                    qualifier = "std_output"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>stdout</default>
                    <option
                        name = "datatype"
                        value = "outfile"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "stdout"
                    >
                    <result
                        name = "std_output"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "std_output_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "4"
                    name = "std_errors"
                    qualifier = "std_errors"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>stderr</default>
                    <option
                        name = "datatype"
                        value = "outfile"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "stderr"
                    >
                    <result
                        name = "std_errors"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "std_errors_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>

            <option
                name = "emboss"
                value = "false"
                type = "normal"
                />
            <option
                name = "installation"
                value = "Soaplab2 default installation"
                type = "normal"
                />

        </analysis_extension>

    </analysis>

</DsLSRAnalysis>
