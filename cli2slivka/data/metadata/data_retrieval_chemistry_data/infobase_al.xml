<DsLSRAnalysis>
    <analysis
        name = "infobase"
        type = "Data retrieval Chemistry data"
        version = "6.6.0.0"
        supplier = "Confosoft Soaplab2 Emboss Docker container"
        installation = "Soaplab2 default installation"
        >
        <description>Return information on a given nucleotide base</description>
        <input
            name = "code"
            type = "string"
            mandatory = "false"
            >
            <default>ABCDGHKMNRSTUVWXY</default>
        </input>

        <output
            name = "report"
            type = "string"
            >
        </output>
        <output
            name = "detailed_status"
            type = "long"
            >
        </output>
        <output
            name = "outfile"
            type = "string"
            >
        </output>
        <output
            name = "outfile_url"
            type = "string"
            >
        </output>

        <analysis_extension>
            <app_info
                category = "data_retrieval_chemistry_data"
                help_URL = "http://emboss.sourceforge.net/apps/release/6.3/emboss/apps/infobase.html"
                />
            <event
                id = "_E_1"
                >
                <action
                    type = "exe"
                    file = "infobase"
                    launcher = ""
                    >
                </action>

            </event>
            <parameter>
                <base
                    ordering = "2"
                    name = "code"
                    qualifier = "code"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>ABCDGHKMNRSTUVWXY</default>
                    <prompt>Nucleotide base code</prompt>
                    <help>Enter IUPAC nucleotide base codes, e.g. A, C, G, T, R, Y etc.</help>
                    <option
                        name = "EDAM_identifier:1007"
                        value = "Nucleotide code"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "nucleotide codes"
                        type = "normal"
                        />
                </base>

                <standard
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </standard>
            </parameter>
            <parameter>
                <base
                    ordering = "7"
                    name = "outfile"
                    qualifier = "outfile"
                    mandatory = "false"
                    type = "string"
                    >
                    <option
                        name = "EDAM_data:0911"
                        value = "Nucleotide base annotation"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "outfile"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "infobase output"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "output"
                    >
                    <result
                        name = "outfile"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "outfile_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>

            <option
                name = "EDAM_operation:2420"
                value = "Analysis and processing"
                type = "normal"
                />
            <option
                name = "EDAM_topic:0154"
                value = "Small molecules"
                type = "normal"
                />
            <option
                name = "emboss"
                value = "true"
                type = "normal"
                />
            <option
                name = "installation"
                value = "Soaplab2 default installation"
                type = "normal"
                />
            <option
                name = "supplier"
                value = "Confosoft Soaplab2 Emboss Docker container"
                type = "normal"
                />
            <option
                name = "version"
                value = "6.6.0.0"
                type = "normal"
                />

        </analysis_extension>

    </analysis>

</DsLSRAnalysis>
