                <base
                    ordering = "17"
                    name = "describe"
                    qualifier = "describe"
                    mandatory = "false"
                    type = "string"
                    >
                    <prompt>Feature tag names to add to the description</prompt>
                    <help>To aid you in identifying some further properties of a
