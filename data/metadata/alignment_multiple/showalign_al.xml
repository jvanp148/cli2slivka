                    <prompt>Plurality check % for consensus</prompt>
                    <help>Set a cut-off for the % of positive scoring matches below
           which there is no consensus. The default plurality is taken as 50%
           of the total weight of all the sequences in the alignment.</help>
                    <option
                        name = "EDAM_data:2146"
                        value = "Threshold"
                        type = "normal"
                        />
