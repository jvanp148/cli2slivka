<DsLSRAnalysis>
    <analysis
        name = "sleep"
        type = "testing"
        installation = "Soaplab2 default installation"
        >
        <description>Just sleep for a while</description>
        <input
            name = "interval"
            type = "long"
            mandatory = "false"
            >
            <default>30</default>
        </input>

        <output
            name = "report"
            type = "string"
            >
        </output>
        <output
            name = "detailed_status"
            type = "long"
            >
        </output>

        <analysis_extension>
            <app_info
                category = "testing"
                />
            <event
                id = "_E_1"
                >
                <action
                    type = "exe"
                    file = "sleep"
                    launcher = ""
                    >
                </action>

            </event>
            <parameter>
                <base
                    ordering = "1"
                    name = "interval"
                    qualifier = "interval"
                    method = "$&quot;interval&quot;"
                    mandatory = "false"
                    type = "long"
                    use_defaults = "true"
                    >
                    <default>30</default>
                    <prompt>Sleeping interval in seconds</prompt>
                </base>

                <range
                    format = "%d"
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </range>
            </parameter>

            <option
                name = "emboss"
                value = "false"
                type = "normal"
                />
            <option
                name = "installation"
                value = "Soaplab2 default installation"
                type = "normal"
                />

        </analysis_extension>

    </analysis>

</DsLSRAnalysis>
