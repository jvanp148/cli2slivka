<DsLSRAnalysis>
    <analysis
        name = "mwcontam"
        type = "Protein Composition"
        version = "6.6.0.0"
        supplier = "Confosoft Soaplab2 Emboss Docker container"
        installation = "Soaplab2 default installation"
        >
        <description>Find weights common to multiple molecular weights files</description>
        <input
            name = "files"
            type = "byte[][]"
            mandatory = "true"
            >
        </input>
        <input
            name = "tolerance"
            type = "float"
            mandatory = "false"
            >
            <default>50.0</default>
        </input>

        <output
            name = "report"
            type = "string"
            >
        </output>
        <output
            name = "detailed_status"
            type = "long"
            >
        </output>
        <output
            name = "outfile"
            type = "string"
            >
        </output>
        <output
            name = "outfile_url"
            type = "string"
            >
        </output>

        <analysis_extension>
            <app_info
                category = "protein_composition"
                help_URL = "http://emboss.sourceforge.net/apps/release/6.3/emboss/apps/mwcontam.html"
                />
            <event
                id = "_E_1"
                >
                <action
                    type = "exe"
                    file = "mwcontam"
                    launcher = ""
                    >
                </action>

            </event>
            <parameter>
                <base
                    ordering = "2"
                    name = "files"
                    qualifier = "files"
                    mandatory = "true"
                    type = "string"
                    input_adaptor = "org.soaplab.services.adaptor.InputManyFiles"
                    >
                    <prompt>Molecular weights file list</prompt>
                    <option
                        name = "EDAM_data:1505"
                        value = "Amino acid index (molecular weight)"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "filelist"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "molecular weights"
                        type = "normal"
                        />
                </base>

                <data
                    iotype = "input"
                    ioformat = "url"
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "4"
                    name = "tolerance"
                    qualifier = "tolerance"
                    mandatory = "false"
                    type = "float"
                    >
                    <default>50.0</default>
                    <prompt>Ppm tolerance</prompt>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                </base>

                <range
                    format = "%f"
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </range>
            </parameter>
            <parameter>
                <base
                    ordering = "6"
                    name = "outfile"
                    qualifier = "outfile"
                    mandatory = "false"
                    type = "string"
                    >
                    <prompt>Molecular weights output file</prompt>
                    <option
                        name = "EDAM_data:1505"
                        value = "Amino acid index (molecular weight)"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "outfile"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "molecular weights"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "output"
                    extension = "mwcontam"
                    >
                    <result
                        name = "outfile"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "outfile_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>

            <option
                name = "EDAM_operation:0398"
                value = "Protein molecular weight calculation"
                type = "normal"
                />
            <option
                name = "EDAM_topic:0157"
                value = "Sequence composition analysis"
                type = "normal"
                />
            <option
                name = "EDAM_topic:0767"
                value = "Protein and peptide identification"
                type = "normal"
                />
            <option
                name = "emboss"
                value = "true"
                type = "normal"
                />
            <option
                name = "installation"
                value = "Soaplab2 default installation"
                type = "normal"
                />
            <option
                name = "supplier"
                value = "Confosoft Soaplab2 Emboss Docker container"
                type = "normal"
                />
            <option
                name = "version"
                value = "6.6.0.0"
                type = "normal"
                />

        </analysis_extension>

    </analysis>

</DsLSRAnalysis>
