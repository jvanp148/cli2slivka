<DsLSRAnalysis>
    <analysis
        name = "featmerge"
        type = "Data retrieval Feature data, Edit"
        version = "6.6.0.0"
        supplier = "Confosoft Soaplab2 Emboss Docker container"
        installation = "Soaplab2 default installation"
        >
        <description>Merge two overlapping feature tables</description>
        <input
            name = "afeatures_direct_data"
            type = "string"
            mandatory = "false"
            >
        </input>
        <input
            name = "afeatures_url"
            type = "string"
            mandatory = "false"
            >
        </input>
        <input
            name = "bfeatures_direct_data"
            type = "string"
            mandatory = "false"
            >
        </input>
        <input
            name = "bfeatures_url"
            type = "string"
            mandatory = "false"
            >
        </input>
        <input
            name = "offormat_outfeat"
            type = "string"
            mandatory = "false"
            >
            <default>gff</default>
            <allowed>gff</allowed>
            <allowed>gff2</allowed>
            <allowed>embl</allowed>
            <allowed>genbank</allowed>
            <allowed>ddbj</allowed>
            <allowed>pir</allowed>
            <allowed>swiss</allowed>
            <allowed>dasgff</allowed>
        </input>

        <output
            name = "report"
            type = "string"
            >
        </output>
        <output
            name = "detailed_status"
            type = "long"
            >
        </output>
        <output
            name = "outfeat"
            type = "string"
            >
        </output>
        <output
            name = "outfeat_url"
            type = "string"
            >
        </output>

        <analysis_extension>
            <app_info
                category = "data_retrieval_feature_data"
                help_URL = "http://emboss.sourceforge.net/apps/release/6.3/emboss/apps/featmerge.html"
                />
            <event
                id = "_E_1"
                >
                <action
                    type = "exe"
                    file = "featmerge"
                    launcher = ""
                    >
                </action>

            </event>
            <parameter>
                <base
                    ordering = "2"
                    name = "afeatures"
                    qualifier = "afeatures"
                    mandatory = "true"
                    type = "string"
                    >
                    <option
                        name = "EDAM_data:1255"
                        value = "Feature record"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "features"
                        type = "normal"
                        />
                </base>

                <data
                    iotype = "input"
                    ioformat = "unspecified"
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "3"
                    name = "bfeatures"
                    qualifier = "bfeatures"
                    mandatory = "true"
                    type = "string"
                    >
                    <option
                        name = "EDAM_data:1255"
                        value = "Feature record"
                        type = "normal"
                        />
                    <option
                        name = "calculated_sequence_type"
                        value = "${acdprotein} ? protein : nucleotide"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "features"
                        type = "normal"
                        />
                </base>

                <data
                    iotype = "input"
                    ioformat = "unspecified"
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "6"
                    name = "outfeat"
                    qualifier = "outfeat"
                    mandatory = "false"
                    type = "string"
                    >
                    <option
                        name = "EDAM_data:1255"
                        value = "Feature record"
                        type = "normal"
                        />
                    <option
                        name = "calculated_sequence_type"
                        value = "${afeatures.type}"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "gendata"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "output"
                    >
                    <result
                        name = "outfeat"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "outfeat_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    name = "offormat_outfeat"
                    qualifier = "offormat_outfeat"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>gff</default>
                    <prompt>Format of the output features (outfeat)</prompt>
                    <option
                        name = "readonly"
                        value = "true"
                        type = "style"
                        />
                </base>

                <standard
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                    <list
                        type = "full"
                        >
                        <list_item
                            value = "gff"
                            level = "0"
                            />
                        <list_item
                            value = "gff2"
                            level = "0"
                            />
                        <list_item
                            value = "embl"
                            level = "0"
                            />
                        <list_item
                            value = "genbank"
                            level = "0"
                            />
                        <list_item
                            value = "ddbj"
                            level = "0"
                            />
                        <list_item
                            value = "pir"
                            level = "0"
                            />
                        <list_item
                            value = "swiss"
                            level = "0"
                            />
                        <list_item
                            value = "dasgff"
                            level = "0"
                            />
                    </list>
                </standard>
            </parameter>

            <option
                name = "EDAM_operation:2422"
                value = "Data retrieval"
                type = "normal"
                />
            <option
                name = "EDAM_topic:0090"
                value = "Data search and retrieval"
                type = "normal"
                />
            <option
                name = "EDAM_topic:0160"
                value = "Sequence sites and features"
                type = "normal"
                />
            <option
                name = "emboss"
                value = "true"
                type = "normal"
                />
            <option
                name = "installation"
                value = "Soaplab2 default installation"
                type = "normal"
                />
            <option
                name = "supplier"
                value = "Confosoft Soaplab2 Emboss Docker container"
                type = "normal"
                />
            <option
                name = "version"
                value = "6.6.0.0"
                type = "normal"
                />

        </analysis_extension>

    </analysis>

</DsLSRAnalysis>
