<DsLSRAnalysis>
    <analysis
        name = "ontogetsibs"
        type = "Ontology, Data retrieval Ontology data"
        version = "6.6.0.0"
        supplier = "Confosoft Soaplab2 Emboss Docker container"
        installation = "Soaplab2 default installation"
        >
        <description>Get ontology term(s) by id with common parent</description>
        <input
            name = "oboterms_direct_data"
            type = "string"
            mandatory = "false"
            >
        </input>
        <input
            name = "oboterms_url"
            type = "string"
            mandatory = "false"
            >
        </input>
        <input
            name = "obsolete"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>

        <output
            name = "report"
            type = "string"
            >
        </output>
        <output
            name = "detailed_status"
            type = "long"
            >
        </output>
        <output
            name = "outfile"
            type = "string"
            >
        </output>
        <output
            name = "outfile_url"
            type = "string"
            >
        </output>

        <analysis_extension>
            <app_info
                category = "ontology"
                help_URL = "http://emboss.sourceforge.net/apps/release/6.3/emboss/apps/ontogetsibs.html"
                />
            <event
                id = "_E_1"
                >
                <action
                    type = "exe"
                    file = "ontogetsibs"
                    launcher = ""
                    >
                </action>

            </event>
            <parameter>
                <base
                    ordering = "2"
                    name = "oboterms"
                    qualifier = "oboterms"
                    mandatory = "false"
                    type = "string"
                    >
                    <option
                        name = "EDAM_identifier:1087"
                        value = "Ontology concept ID"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "obo"
                        type = "normal"
                        />
                </base>

                <data
                    iotype = "input"
                    ioformat = "unspecified"
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "8"
                    name = "outfile"
                    qualifier = "outfile"
                    mandatory = "false"
                    type = "string"
                    >
                    <option
                        name = "EDAM_data:0966"
                        value = "Ontology term"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "outfile"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "output"
                    >
                    <result
                        name = "outfile"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "outfile_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "4"
                    name = "obsolete"
                    qualifier = "obsolete"
                    mandatory = "false"
                    type = "boolean"
                    >
                    <default>false</default>
                    <prompt>Include obsolete terms</prompt>
                    <help>The default behaviour is to not use or return obsolete terms.
           This option if set will include all terms.</help>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                </base>

            </parameter>

            <option
