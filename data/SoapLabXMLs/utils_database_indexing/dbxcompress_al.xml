                    <option
                        name = "datatype"
                        value = "filelist"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "emboss database index"
                        type = "normal"
                        />
                </base>

                <data
                    iotype = "input"
                    ioformat = "url"
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>

            <option
