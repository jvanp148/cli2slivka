<DsLSRAnalysis>
    <analysis
        name = "dbxcompress"
        type = "Utils Database indexing"
        version = "6.6.0.0"
        supplier = "Confosoft Soaplab2 Emboss Docker container"
        installation = "Soaplab2 default installation"
        >
        <description>Compress an uncompressed dbx index</description>
        <input
            name = "dbname"
            type = "string"
            mandatory = "true"
            >
        </input>
        <input
            name = "field"
            type = "string"
            mandatory = "false"
            >
        </input>
        <input
            name = "indexdir"
            type = "byte[][]"
            mandatory = "false"
            >
        </input>

        <output
            name = "report"
            type = "string"
            >
        </output>
        <output
            name = "detailed_status"
            type = "long"
            >
        </output>
        <output
            name = "outfile"
            type = "string"
            >
        </output>
        <output
            name = "outfile_url"
            type = "string"
            >
        </output>

        <analysis_extension>
            <app_info
                category = "utils_database_indexing"
                help_URL = "http://emboss.sourceforge.net/apps/release/6.3/emboss/apps/dbxcompress.html"
                />
            <event
                id = "_E_1"
                >
                <action
                    type = "exe"
                    file = "dbxcompress"
                    launcher = ""
                    >
                </action>

            </event>
            <parameter>
                <base
                    ordering = "2"
                    name = "dbname"
                    qualifier = "dbname"
                    mandatory = "true"
                    type = "string"
                    >
                    <prompt>EMBOSS database name</prompt>
                    <option
                        name = "EDAM_identifier:1056"
                        value = "Database name"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "emboss database name"
                        type = "normal"
                        />
                </base>

                <standard
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </standard>
            </parameter>
            <parameter>
                <base
                    ordering = "3"
                    name = "field"
                    qualifier = "field"
                    mandatory = "false"
                    type = "string"
                    >
                    <prompt>EMBOSS database field</prompt>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "emboss database field"
                        type = "normal"
                        />
                </base>

                <standard
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </standard>
            </parameter>
            <parameter>
                <base
                    ordering = "9"
                    name = "outfile"
                    qualifier = "outfile"
                    mandatory = "false"
                    type = "string"
                    >
                    <option
                        name = "EDAM_data:2048"
                        value = "Report"
                        type = "normal"
                        />
                    <option
                        name = "calculated_label"
                        value = "${dbname}"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "outfile"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "dbxcompress output"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "output"
                    >
                    <result
                        name = "outfile"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "outfile_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "4"
                    name = "indexdir"
                    qualifier = "indexdir"
