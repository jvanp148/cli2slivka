                        <list_item
                            value = "pc"
                            shown_as = "Windows/DOS"
                            level = "0"
                            />
                        <list_item
                            value = "mac"
                            shown_as = "Apple
             Macintosh"
                            level = "0"
                            />
                    </list>
                </standard>
            </parameter>

            <option
