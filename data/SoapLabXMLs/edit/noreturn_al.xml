        version = "6.6.0.0"
        supplier = "Confosoft Soaplab2 Emboss Docker container"
        installation = "Soaplab2 default installation"
        >
        <description>Remove carriage return from ASCII files</description>
        <input
            name = "infile_direct_data"
            type = "string"
            mandatory = "false"
            >
        </input>
        <input
            name = "infile_url"
            type = "string"
            mandatory = "false"
            >
        </input>
        <input
            name = "system"
            type = "string"
            mandatory = "false"
            >
            <default>unix</default>
            <allowed>unix</allowed>  <!-- Unix/Linux systems -->
            <allowed>pc</allowed>  <!-- Windows/DOS -->
            <allowed>mac</allowed>  <!-- Apple
             Macintosh -->
        </input>

        <output
            name = "report"
            type = "string"
            >
        </output>
        <output
            name = "detailed_status"
            type = "long"
            >
        </output>
        <output
            name = "outfile"
            type = "string"
            >
        </output>
        <output
            name = "outfile_url"
            type = "string"
            >
        </output>

        <analysis_extension>
            <app_info
                category = "edit"
                help_URL = "http://emboss.sourceforge.net/apps/release/6.3/emboss/apps/noreturn.html"
                />
            <event
                id = "_E_1"
                >
                <action
                    type = "exe"
                    file = "noreturn"
                    launcher = ""
                    >
                </action>

            </event>
            <parameter>
                <base
                    ordering = "2"
                    name = "infile"
                    qualifier = "infile"
                    mandatory = "true"
                    type = "string"
                    >
                    <prompt>ASCII text file</prompt>
                    <option
                        name = "EDAM_data:2048"
                        value = "Report"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "input"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "ascii text"
                        type = "normal"
                        />
                </base>

                <data
                    iotype = "input"
                    ioformat = "unspecified"
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "7"
                    name = "outfile"
                    qualifier = "outfile"
                    mandatory = "false"
                    type = "string"
                    >
                    <prompt>ASCII text output file</prompt>
                    <option
                        name = "EDAM_data:2048"
                        value = "Report"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "outfile"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "ascii text"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "output"
                    >
                    <result
                        name = "outfile"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "outfile_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "4"
                    name = "system"
                    qualifier = "system"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>unix</default>
                    <prompt>Target operating system for end-of-line
                  format</prompt>
                    <option
                        name = "EDAM_identifier:2131"
                        value = "Operating system name"
                        type = "normal"
                        />
