<DsLSRAnalysis>
    <analysis
        name = "cachedas"
        type = "Data resources"
        version = "6.6.0.0"
        supplier = "Confosoft Soaplab2 Emboss Docker container"
        installation = "Soaplab2 default installation"
        >
        <description>Generate server cache file for DAS servers or for the DAS registry</description>
        <input
            name = "sequencesourcesonly"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "host"
            type = "string"
            mandatory = "false"
            >
            <default>www.dasregistry.org</default>
        </input>
        <input
            name = "path"
            type = "string"
            mandatory = "false"
            >
            <default>/das</default>
        </input>
        <input
            name = "port"
            type = "long"
            mandatory = "false"
            >
            <default>80</default>
        </input>
        <input
            name = "servername"
            type = "string"
            mandatory = "false"
            >
            <default>das</default>
        </input>

        <output
            name = "report"
            type = "string"
            >
        </output>
        <output
            name = "detailed_status"
            type = "long"
            >
        </output>
        <output
            name = "cachefile"
            type = "string"
            >
        </output>
        <output
            name = "cachefile_url"
            type = "string"
            >
        </output>
        <output
            name = "outfile"
            type = "string"
            >
        </output>
        <output
            name = "outfile_url"
            type = "string"
            >
        </output>

        <analysis_extension>
            <app_info
                category = "data_resources"
                help_URL = "http://emboss.sourceforge.net/apps/release/6.3/emboss/apps/cachedas.html"
                />
            <event
                id = "_E_1"
                >
                <action
                    type = "exe"
                    file = "cachedas"
                    launcher = ""
                    >
                </action>

            </event>
            <parameter>
                <base
                    ordering = "10"
                    name = "cachefile"
                    qualifier = "cachefile"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>server.$(servername)</default>
                    <prompt>Server cache output file</prompt>
                    <option
                        name = "EDAM_data:2048"
                        value = "Report"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "outfile"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "emboss server cache file"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "output"
                    >
                    <result
                        name = "cachefile"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "cachefile_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "2"
                    name = "sequencesourcesonly"
                    qualifier = "sequencesourcesonly"
                    mandatory = "false"
                    type = "boolean"
                    >
                    <default>false</default>
                    <prompt>Display DAS sequence sources only</prompt>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                </base>

            </parameter>
            <parameter>
                <base
                    ordering = "3"
                    name = "host"
                    qualifier = "host"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>www.dasregistry.org</default>
                    <prompt>DAS registry/server host location</prompt>
                    <option
                        name = "EDAM_data:1047"
                        value = "URI"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "url host address"
                        type = "normal"
                        />
                </base>

                <standard
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </standard>
            </parameter>
            <parameter>
                <base
                    ordering = "4"
                    name = "path"
                    qualifier = "path"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>/das</default>
                    <prompt>DAS registry/server path on registry/server host</prompt>
                    <option
                        name = "EDAM_identifier:1049"
                        value = "Directory name"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "url path"
                        type = "normal"
                        />
                </base>

                <standard
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </standard>
            </parameter>
            <parameter>
                <base
                    ordering = "5"
                    name = "port"
                    qualifier = "port"
                    mandatory = "false"
                    type = "long"
                    >
                    <default>80</default>
                    <prompt>DAS registry/server port on registry/server host</prompt>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "url port"
                        type = "normal"
                        />
                </base>

                <range
                    format = "%d"
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </range>
            </parameter>
            <parameter>
                <base
                    ordering = "6"
                    name = "servername"
                    qualifier = "servername"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>das</default>
                    <prompt>Name of a DAS server defined in EMBOSS resource files</prompt>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "emboss server name"
                        type = "normal"
                        />
                </base>

                <standard
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </standard>
            </parameter>
            <parameter>
                <base
                    ordering = "9"
                    name = "outfile"
                    qualifier = "outfile"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>stdout</default>
                    <option
                        name = "EDAM_data:2048"
                        value = "Report"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "outfile"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "cachedas output"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "stdout"
                    >
                    <result
                        name = "outfile"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "outfile_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>

            <option
                name = "EDAM_operation:0516"
                value = "Data retrieval (database metadata)"
                type = "normal"
                />
            <option
                name = "EDAM_topic:0091"
                value = "Data handling"
                type = "normal"
                />
            <option
                name = "emboss"
                value = "true"
                type = "normal"
                />
            <option
                name = "installation"
                value = "Soaplab2 default installation"
                type = "normal"
                />
            <option
                name = "supplier"
                value = "Confosoft Soaplab2 Emboss Docker container"
                type = "normal"
                />
            <option
                name = "version"
                value = "6.6.0.0"
                type = "normal"
                />

        </analysis_extension>

    </analysis>

</DsLSRAnalysis>
