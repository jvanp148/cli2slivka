<DsLSRAnalysis>
    <analysis
        name = "dbtell"
        type = "Data resources"
        version = "6.6.0.0"
        supplier = "Confosoft Soaplab2 Emboss Docker container"
        installation = "Soaplab2 default installation"
        >
        <description>Display information about a public database</description>
        <input
            name = "database"
            type = "string"
            mandatory = "false"
            >
        </input>
        <input
            name = "full"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>
        <input
            name = "server"
            type = "string"
            mandatory = "false"
            >
        </input>

        <output
            name = "report"
            type = "string"
            >
        </output>
        <output
            name = "detailed_status"
            type = "long"
            >
        </output>
        <output
            name = "outfile"
            type = "string"
            >
        </output>
        <output
            name = "outfile_url"
            type = "string"
            >
        </output>

        <analysis_extension>
            <app_info
                category = "data_resources"
                help_URL = "http://emboss.sourceforge.net/apps/release/6.3/emboss/apps/dbtell.html"
                />
            <event
                id = "_E_1"
                >
                <action
                    type = "exe"
                    file = "dbtell"
                    launcher = ""
                    >
                </action>

            </event>
            <parameter>
                <base
                    ordering = "2"
                    name = "database"
                    qualifier = "database"
                    mandatory = "false"
                    type = "string"
                    >
                    <prompt>Database name</prompt>
                    <help>The name of the database defined locally for use by EMBOSS.</help>
                    <option
                        name = "EDAM_identifier:1048"
                        value = "Database identifier"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "emboss database name"
                        type = "normal"
                        />
                </base>

                <standard
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </standard>
            </parameter>
            <parameter>
                <base
                    ordering = "4"
                    name = "full"
                    qualifier = "full"
                    mandatory = "false"
                    type = "boolean"
                    >
                    <default>false</default>
                    <prompt>Verbose output</prompt>
                    <help>The default behaviour is to report for relevant databases only
           basic information from the EMBOSS database definition</help>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                </base>

            </parameter>
            <parameter>
                <base
                    ordering = "7"
                    name = "server"
                    qualifier = "server"
                    mandatory = "false"
                    type = "string"
                    >
                    <prompt>Server name</prompt>
                    <help>The name of the server defined locally for use by EMBOSS.</help>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "emboss server name"
                        type = "normal"
                        />
                </base>

                <standard
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </standard>
            </parameter>
            <parameter>
                <base
                    ordering = "10"
                    name = "outfile"
                    qualifier = "outfile"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>stdout</default>
                    <option
                        name = "EDAM_data:0957"
                        value = "Database metadata"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "outfile"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "dbtell output"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "stdout"
                    >
                    <result
                        name = "outfile"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "outfile_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>

            <option
                name = "EDAM_operation:0516"
                value = "Data retrieval (database metadata)"
                type = "normal"
                />
            <option
                name = "EDAM_topic:0091"
                value = "Data handling"
                type = "normal"
                />
            <option
                name = "emboss"
                value = "true"
                type = "normal"
                />
            <option
                name = "installation"
                value = "Soaplab2 default installation"
                type = "normal"
                />
            <option
                name = "supplier"
                value = "Confosoft Soaplab2 Emboss Docker container"
                type = "normal"
                />
            <option
                name = "version"
                value = "6.6.0.0"
                type = "normal"
                />

        </analysis_extension>

    </analysis>

</DsLSRAnalysis>
