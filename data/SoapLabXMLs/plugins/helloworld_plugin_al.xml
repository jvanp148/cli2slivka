<DsLSRAnalysis>
    <analysis
        name = "helloworld_plugin"
        type = "Plugins"
        installation = "Soaplab2 default installation"
        >
        <description>Classic greeting from the beginning of the UNIX epoch</description>
        <input
            name = "greeting"
            type = "string"
            mandatory = "false"
            >
            <default>Hello World</default>
        </input>

        <output
            name = "report"
            type = "string"
            >
        </output>
        <output
            name = "detailed_status"
            type = "long"
            >
        </output>
        <output
            name = "output"
            type = "string"
            >
        </output>
        <output
            name = "output_url"
            type = "string"
            >
        </output>

        <analysis_extension>
            <app_info
                category = "plugins"
                />
            <event
                id = "_E_1"
                >
                <action
                    type = "exe"
                    file = "helloworld_plugin"
                    launcher = ""
                    >
                </action>

            </event>
            <parameter>
                <base
                    ordering = "1"
                    name = "greeting"
                    qualifier = "greeting"
                    method = "$&quot;greeting&quot;"
                    mandatory = "false"
                    type = "string"
                    use_defaults = "true"
                    >
                    <default>Hello World</default>
                </base>

                <standard
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </standard>
            </parameter>
            <parameter>
                <base
                    ordering = "2"
                    name = "output"
                    qualifier = "output"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>stdout</default>
                    <option
                        name = "datatype"
                        value = "outfile"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "stdout"
                    >
                    <result
                        name = "output"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "output_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>

            <option
                name = "class"
                value = "org.soaplab.samples.HelloWorldJobFactory"
                type = "normal"
                />
            <option
                name = "emboss"
                value = "false"
                type = "normal"
                />
            <option
                name = "installation"
                value = "Soaplab2 default installation"
                type = "normal"
                />

        </analysis_extension>

    </analysis>

</DsLSRAnalysis>
