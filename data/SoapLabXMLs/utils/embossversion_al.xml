<DsLSRAnalysis>
    <analysis
        name = "embossversion"
        type = "Utils"
        version = "6.6.0.0"
        supplier = "Confosoft Soaplab2 Emboss Docker container"
        installation = "Soaplab2 default installation"
        >
        <description>Report the current EMBOSS version number</description>
        <input
            name = "full"
            type = "boolean"
            mandatory = "false"
            >
            <default>false</default>
        </input>

        <output
            name = "report"
            type = "string"
            >
        </output>
        <output
            name = "detailed_status"
            type = "long"
            >
        </output>
        <output
            name = "outfile"
            type = "string"
            >
        </output>
        <output
            name = "outfile_url"
            type = "string"
            >
        </output>

        <analysis_extension>
            <app_info
                category = "utils"
                help_URL = "http://emboss.sourceforge.net/apps/release/6.3/emboss/apps/embossversion.html"
                />
            <event
                id = "_E_1"
                >
                <action
                    type = "exe"
                    file = "embossversion"
                    launcher = ""
                    >
                </action>

            </event>
            <parameter>
                <base
                    ordering = "2"
                    name = "full"
                    qualifier = "full"
                    mandatory = "false"
                    type = "boolean"
                    >
                    <default>false</default>
                    <prompt>Show all EMBOSS version information fields</prompt>
                    <option
                        name = "EDAM_data:2527"
                        value = "Parameter"
                        type = "normal"
                        />
                </base>

            </parameter>
            <parameter>
                <base
                    ordering = "5"
                    name = "outfile"
                    qualifier = "outfile"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>stdout</default>
                    <prompt>EMBOSS version output file</prompt>
                    <option
                        name = "EDAM_data:1671"
                        value = "Tool version information"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "outfile"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "embossversion output"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "stdout"
                    >
                    <result
                        name = "outfile"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "outfile_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>

            <option
                name = "EDAM_operation:0515"
                value = "Data retrieval (tool metadata)"
                type = "normal"
                />
            <option
                name = "EDAM_topic:0091"
                value = "Data handling"
                type = "normal"
                />
            <option
                name = "emboss"
                value = "true"
                type = "normal"
                />
            <option
                name = "installation"
                value = "Soaplab2 default installation"
                type = "normal"
                />
            <option
                name = "supplier"
                value = "Confosoft Soaplab2 Emboss Docker container"
                type = "normal"
                />
            <option
                name = "version"
                value = "6.6.0.0"
                type = "normal"
                />

