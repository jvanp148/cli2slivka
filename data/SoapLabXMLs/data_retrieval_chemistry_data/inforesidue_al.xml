<DsLSRAnalysis>
    <analysis
        name = "inforesidue"
        type = "Data retrieval Chemistry data"
        version = "6.6.0.0"
        supplier = "Confosoft Soaplab2 Emboss Docker container"
        installation = "Soaplab2 default installation"
        >
        <description>Return information on a given amino acid residue</description>
        <input
            name = "code"
            type = "string"
            mandatory = "false"
            >
            <default>ABCDEFGHIJKLMNOPQRSTUVWXYZ</default>
        </input>
        <input
            name = "aadata_direct_data"
            type = "string"
            mandatory = "false"
            >
        </input>
        <input
            name = "aadata_url"
            type = "string"
            mandatory = "false"
            >
            <default>Eamino.dat</default>
        </input>
        <input
            name = "mwdata_direct_data"
            type = "string"
            mandatory = "false"
            >
        </input>
        <input
            name = "mwdata_url"
            type = "string"
            mandatory = "false"
            >
            <default>Emolwt.dat</default>
        </input>

        <output
            name = "report"
            type = "string"
            >
        </output>
        <output
            name = "detailed_status"
            type = "long"
            >
        </output>
        <output
            name = "outfile"
            type = "string"
            >
        </output>
        <output
            name = "outfile_url"
            type = "string"
            >
        </output>

        <analysis_extension>
            <app_info
                category = "data_retrieval_chemistry_data"
                help_URL = "http://emboss.sourceforge.net/apps/release/6.3/emboss/apps/inforesidue.html"
                />
            <event
                id = "_E_1"
                >
                <action
                    type = "exe"
                    file = "inforesidue"
                    launcher = ""
                    >
                </action>

            </event>
            <parameter>
                <base
                    ordering = "2"
                    name = "code"
                    qualifier = "code"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>ABCDEFGHIJKLMNOPQRSTUVWXYZ</default>
                    <prompt>Amino acid residue code</prompt>
                    <help>Enter IUPAC amino acids codes, e.g. A, C, D, E etc.</help>
                    <option
                        name = "EDAM_identifier:0994"
                        value = "Amino acid identifier"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "protein codes"
                        type = "normal"
                        />
                </base>

                <standard
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </standard>
            </parameter>
            <parameter>
                <base
                    ordering = "10"
                    name = "outfile"
                    qualifier = "outfile"
                    mandatory = "false"
                    type = "string"
                    >
                    <option
                        name = "EDAM_data:0894"
                        value = "Amino acid annotation"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "outfile"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "inforesidue output"
                        type = "normal"
                        />
                    <option
                        name = "nodisplay"
                        value = "true"
                        type = "style"
                        />
                </base>

                <data
                    iotype = "output"
                    >
                    <result
                        name = "outfile"
                        type = "string"
                        >
                    </result>
                    <result
                        name = "outfile_url"
                        type = "string"
                        special_type = "url"
                        >
                    </result>
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "3"
                    name = "aadata"
                    qualifier = "aadata"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>Eamino.dat</default>
                    <prompt>Amino acids properties and molecular weight data file</prompt>
                    <help>Amino acid properties</help>
                    <option
                        name = "EDAM_data:1502"
                        value = "Amino acid index (chemical classes)"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "datafile"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "amino acid properties"
                        type = "normal"
                        />
                </base>

                <data
                    iotype = "input"
                    ioformat = "unspecified"
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>
            <parameter>
                <base
                    ordering = "4"
                    name = "mwdata"
                    qualifier = "mwdata"
                    mandatory = "false"
                    type = "string"
                    >
                    <default>Emolwt.dat</default>
                    <prompt>Molecular weights data file</prompt>
                    <help>Molecular weight data for amino acids</help>
                    <option
                        name = "EDAM_data:1505"
                        value = "Amino acid index (molecular weight)"
                        type = "normal"
                        />
                    <option
                        name = "datatype"
                        value = "datafile"
                        type = "normal"
                        />
                    <option
                        name = "knowntype"
                        value = "molecular weights"
                        type = "normal"
                        />
                </base>

                <data
                    iotype = "input"
                    ioformat = "unspecified"
                    >
                    <repeatable
                        min = "0"
                        max = "0"
                        >
                    </repeatable>
                </data>
            </parameter>

            <option
                name = "EDAM_operation:2420"
                value = "Analysis and processing"
                type = "normal"
                />
            <option
                name = "EDAM_topic:0154"
                value = "Small molecules"
                type = "normal"
                />
            <option
                name = "emboss"
                value = "true"
                type = "normal"
                />
            <option
                name = "installation"
                value = "Soaplab2 default installation"
                type = "normal"
                />
            <option
                name = "supplier"
                value = "Confosoft Soaplab2 Emboss Docker container"
                type = "normal"
                />
            <option
                name = "version"
                value = "6.6.0.0"
                type = "normal"
                />

        </analysis_extension>

    </analysis>

</DsLSRAnalysis>
